function buildKRAFooter(deptKey, col){
  const kras = KRA_DATA[deptKey] || [];
  const dotColor = col ? col.dot : '#5A5652';
  const lightColor = col ? col.light : '#F0EEE9';
  const textColor = col ? col.text : '#3A3835';
  const items = kras.length > 0
    ? kras.map(k=>`<div class="kra-item">
