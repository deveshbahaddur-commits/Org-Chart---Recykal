    '<span class="badge b-cc" style="margin-left:auto;background:var(--gray-l,#F0EEE9);color:#3A3835">Facility Mgmt</span>'+
    '<span class="badge b-ok">'+active+' Active</span>'+
    '<span class="badge" style="background:var(--amber-l);color:var(--amber-d)">'+fmt(totalCost)+'</span>';
  document.getElementById('dept-row').innerHTML=FACILITY_DEPTS.map(function(d){return buildDeptCol(d,ccEmps);}).join('');
}

function renderCompliance(ccEmps){
  var pl=byId['RT0994'];
  var active=ccEmps.filter(function(e){return e.status==='Active';}).length;
  var totalCost=ccEmps.filter(function(e){return e.status==='Active';}).reduce(function(s,e){return s+(e.cost||0);},0);
  document.getElementById('org-top').innerHTML=
    '<div class="pl-av av-amber">'+ini(pl.name)+'</div>'+
    '<div><div class="pl-name" style="cursor:pointer" onclick="showTip(this.dataset.id,this)" data-id="'+pl.id+'">'+pl.name+'</div>'+
    '<div class="pl-desig">'+pl.desig+'</div></div>'+
    '<span class="badge b-cc" style="margin-left:auto;background:var(--amber-l);color:var(--amber-d)">Compliance</span>'+
    '<span class="badge b-ok">'+active+' Active</span>'+
    '<span class="badge" style="background:var(--amber-l);color:var(--amber-d)">'+fmt(totalCost)+'</span>';
  document.getElementById('dept-row').innerHTML=COMPLIANCE_DEPTS.map(function(d){return buildDeptCol(d,ccEmps);}).join('');
}

function renderAFR(ccEmps){
  var active=ccEmps.filter(function(e){return e.status==='Active';}).length;
  var resigned=ccEmps.filter(function(e){return e.status==='Resigned';}).length;
  var totalCost=ccEmps.filter(function(e){return e.status==='Active';}).reduce(function(s,e){return s+(e.cost||0);},0);
  document.getElementById('org-top').innerHTML=
    '<div class="pl-av av-gray" style="font-size:10px">AFR</div>'+
    '<div><div style="font-size:14px;font-weight:600">AFR</div>'+
    '<div class="pl-desig">Reporting to Ekta Narain &amp; Ila Florance Joseph</div></div>'+
    '<span class="badge b-cc" style="margin-left:auto">AFR</span>'+
    '<span class="badge b-ok">'+active+' Active</span>'+
    (resigned>0?'<span class="badge b-rs">'+resigned+' Resigned</span>':'')+
    '<span class="badge" style="background:var(--amber-l);color:var(--amber-d)">'+fmt(totalCost)+'</span>';
  document.getElementById('dept-row').innerHTML=AFR_DEPTS.map(function(d){return buildDeptCol(d,ccEmps);}).join('');
}

function render(cc){
  currentCC = cc;
  const ccEmps=cc==='Finance'
    ? EMP.filter(e=>e.cc==='Finance')
    : EMP.filter(e=>e.cc===cc);
  buildStats(ccEmps,cc);
  if(cc==='EPR')renderEPR(ccEmps);
  else if(cc==='AFR')renderAFR(ccEmps);
  else if(cc==='Finance')renderFinance(ccEmps);
  else if(cc==='PC')renderPC(ccEmps);
  else if(cc==='Technology')renderTech(ccEmps);
  else if(cc==='Retearn')renderRetearn(ccEmps);
  else if(cc==='Infra')renderInfra(ccEmps);
  else if(cc==='AWF')renderAWF(ccEmps);
  else if(cc==='OC')renderOC(ccEmps);
  else if(cc==='Facility')renderFacility(ccEmps);
  else if(cc==='Compliance')renderCompliance(ccEmps);
  else renderGenericCC(cc,ccEmps);
}

function selectCC(btn,cc){
  document.querySelectorAll('.cc-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');hideTip();render(cc);
}

document.getElementById('nav-date').textContent=new Date().toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'});
document.addEventListener('keydown',e=>{if(e.key==='Escape')hideTip();});
render('EPR');
</script>
</body>
</html>
