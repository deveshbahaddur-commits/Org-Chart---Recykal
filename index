// ── DEPT COLUMN BUILDER ──
function buildDeptCol(dept, ccEmps){
  const col=DEPT_C[dept.color]||DEPT_C.gray;
  const deptEmps=ccEmps.filter(e=>{
    const d=(e.dept||'').toLowerCase(),k=dept.key.toLowerCase();
    return d===k||d.includes(k.split(' ')[0])||k.includes(d.split(' ')[0]);
  });
  const activeCnt=deptEmps.filter(e=>e.status==='Active').length;
  const topCards=dept.topLevelIds.map(id=>byId[id]).filter(Boolean)
    .map(e=>renderTopCard(e,dept.color)).join('');
  return`<div class="dept-col">
    <div class="dept-hd">
      <div class="dept-hd-row">
        <div class="dept-title"><span class="dept-dot" style="background:${col.dot}"></span>${dept.key}</div>
