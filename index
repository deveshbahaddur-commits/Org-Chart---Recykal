<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Org Chart Dashboard — Recykal</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#F5F4F1;--surface:#FFF;--surface2:#F0EEE9;--border:#E2DED6;--border2:#C8C4BC;
  --text:#1A1916;--text2:#6B6760;--text3:#A09C96;
  --purple:#4F46A0;--purple-l:#ECEAFF;--purple-d:#3C3489;
  --teal:#0E6E57;--teal-l:#E0F4EE;--teal-d:#074E3D;
  --amber:#B06B14;--amber-l:#FEF0DC;--amber-d:#7A4A0C;
  --green:#2F6B1A;--green-l:#EAF4E2;--green-d:#1D4510;
  --blue:#1558A0;--blue-l:#E5EFFC;--blue-d:#0C3C72;
  --indigo:#3730A3;--indigo-l:#EEF2FF;--indigo-d:#312E81;
  --rose:#9D174D;--rose-l:#FCE7F3;--rose-d:#831843;
  --red:#A32828;--red-l:#FDE8E8;
  --r:8px;--r-lg:12px;
  --shadow:0 2px 8px rgba(0,0,0,.08);--shadow-lg:0 8px 24px rgba(0,0,0,.12);
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);font-size:13px;line-height:1.5;min-height:100vh}
.nav{background:var(--surface);border-bottom:1px solid var(--border);height:50px;padding:0 22px;display:flex;align-items:center;gap:16px;position:sticky;top:0;z-index:200}
.logo{font-size:15px;font-weight:600;letter-spacing:-.3px;display:flex;align-items:center;gap:7px}
.logo-dot{width:8px;height:8px;border-radius:50%;background:var(--purple)}
.nav-sep{width:1px;height:20px;background:var(--border)}
.nav-sub{font-size:12px;color:var(--text2)}
.nav-date{margin-left:auto;font-family:'DM Mono',monospace;font-size:11px;color:var(--text3)}
.cc-bar{background:var(--surface);border-bottom:1px solid var(--border);height:44px;padding:0 22px;display:flex;align-items:center;gap:6px}
.cc-label{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);margin-right:6px}
.cc-btn{height:26px;padding:0 13px;border-radius:20px;border:1px solid var(--border);background:transparent;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;color:var(--text2);cursor:pointer;transition:all .14s}
.cc-btn:hover{border-color:var(--border2);background:var(--surface2);color:var(--text)}
.cc-btn.active{background:var(--text);color:#fff;border-color:var(--text)}
.main{padding:18px 22px}
.stats{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:16px}
.sc{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:11px 13px}
.sc-lbl{font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);font-weight:500;margin-bottom:4px}
.sc-val{font-size:24px;font-weight:600;letter-spacing:-1px;line-height:1}
.sc-sub{font-size:10px;color:var(--text3);margin-top:2px}
.val-green{color:var(--teal)}.val-red{color:var(--red)}.val-amber{color:var(--amber)}
.org-wrap{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);overflow:visible}
.org-top{padding:12px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.pl-av{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0}
.pl-name{font-size:14px;font-weight:600;cursor:pointer}
.pl-name:hover{color:var(--purple)}
.pl-desig{font-size:11px;color:var(--text2)}
.badge{font-size:10px;font-weight:600;padding:2px 9px;border-radius:20px;letter-spacing:.03em}
.b-cc{background:var(--purple-l);color:var(--purple-d)}
.b-ok{background:var(--teal-l);color:var(--teal-d)}
.b-rs{background:var(--red-l);color:var(--red)}
.dept-row{display:flex;min-height:calc(100vh - 300px);align-items:flex-start;overflow-x:auto;overflow-y:visible}
.dept-col{flex:1;min-width:220px;border-right:1px solid var(--border);display:flex;flex-direction:column}
.dept-col:last-child{border-right:none}
.dept-hd{padding:10px 13px;border-bottom:1px solid var(--border);background:var(--surface);position:sticky;top:0;z-index:10}
.dept-hd-row{display:flex;align-items:center;justify-content:space-between}
.dept-title{font-size:12px;font-weight:600;display:flex;align-items:center;gap:6px}
.dept-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.dept-cnt{font-size:10px;font-weight:600;padding:1px 7px;border-radius:20px}
.dept-body{padding:10px;flex:1;overflow-y:visible}
/* person cards */
.pcard{border:1px solid var(--border);border-radius:var(--r);padding:8px 10px;background:var(--surface);margin-bottom:5px;display:flex;align-items:center;gap:8px;transition:all .14s;position:relative}
.pcard:hover{border-color:var(--border2);box-shadow:var(--shadow);transform:translateY(-1px)}
.pcard.sel{border-color:var(--purple);background:var(--purple-l)}
.pcard.resigned-card{opacity:.5}
.p-av{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;flex-shrink:0}
.p-info{flex:1;min-width:0}
.p-name{font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer;display:inline}
.p-name:hover{color:var(--purple);text-decoration:underline}
.p-fn{font-size:10px;font-weight:600;color:var(--blue);margin-bottom:1px}
.p-role{font-size:10px;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px}
.p-right{display:flex;align-items:center;gap:5px;flex-shrink:0}
.expand-btn{font-size:11px;font-weight:600;background:var(--surface2);border:1px solid var(--border);color:var(--text2);padding:2px 7px;border-radius:20px;cursor:pointer;transition:all .14s;white-space:nowrap}
.expand-btn:hover{background:var(--text);color:#fff;border-color:var(--text)}
.chev{font-size:15px;color:var(--text3);transition:transform .18s;line-height:1;cursor:pointer}
.chev.open{transform:rotate(90deg)}
.status-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.drill{display:none;margin:0 0 6px 16px;border-left:2px solid var(--border);padding-left:10px}
.drill.open{display:block}
/* sub-team pill inside drawer */
.fn-pill{display:inline-flex;align-items:center;gap:4px;font-size:9px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;padding:2px 8px;border-radius:20px;margin:5px 0 3px;background:var(--blue-l);color:var(--blue-d)}
.fn-pill.green{background:var(--green-l);color:var(--green-d)}
.fn-pill.amber{background:var(--amber-l);color:var(--amber-d)}
.fn-pill.indigo{background:var(--indigo-l);color:var(--indigo-d)}
.scard{display:flex;align-items:center;gap:7px;padding:5px 8px;border-radius:6px;cursor:pointer;transition:background .12s;margin-bottom:2px;border:1px solid transparent}
.scard:hover{background:var(--surface2);border-color:var(--border)}
.scard.sel{background:var(--purple-l);border-color:#C8C4F0}
.scard.resigned-card{opacity:.5}
.s-av{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;flex-shrink:0}
.s-info{flex:1;min-width:0}
.s-name{font-size:11px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer;display:inline}
.s-name:hover{color:var(--purple);text-decoration:underline}
.s-role{font-size:10px;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.s-right{display:flex;align-items:center;gap:4px;flex-shrink:0}
.s-expand{font-size:10px;font-weight:600;background:var(--surface2);border:1px solid var(--border);color:var(--text2);padding:1px 6px;border-radius:20px;cursor:pointer;transition:all .12s}
.s-expand:hover{background:var(--text);color:#fff;border-color:var(--text)}
.s-chev{font-size:13px;color:var(--text3);transition:transform .18s;line-height:1;cursor:pointer}
.s-chev.open{transform:rotate(90deg)}
.drill2{display:none;margin:0 0 4px 14px;border-left:1.5px solid var(--border);padding-left:8px}
.drill2.open{display:block}
.tcard{display:flex;align-items:center;gap:6px;padding:4px 6px;border-radius:5px;cursor:pointer;transition:background .1s;margin-bottom:1px}
.tcard:hover{background:var(--surface2)}
.tcard.sel{background:var(--purple-l)}
.t-av{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:7px;font-weight:700;flex-shrink:0;background:var(--surface2);color:var(--text2)}
.t-name{font-size:10px;font-weight:500;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer}
.t-name:hover{color:var(--purple);text-decoration:underline}
.t-role{font-size:9px;color:var(--text3)}
/* consultant tag */
.ric-tag{font-size:8px;padding:1px 5px;border-radius:10px;background:#FEF0DC;color:#7A4A0C;border:1px solid #F0D5A0;flex-shrink:0;margin-left:2px}
/* tooltip */
.tip{position:fixed;background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);box-shadow:var(--shadow-lg);width:260px;z-index:500;overflow:hidden;animation:tipIn .14s ease;pointer-events:auto}
@keyframes tipIn{from{opacity:0;transform:translateY(4px) scale(.97)}to{opacity:1;transform:none}}
.tip-head{padding:14px 14px 10px;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;gap:10px}
.tip-av{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;flex-shrink:0}
.tip-name{font-size:14px;font-weight:600;margin-bottom:2px;letter-spacing:-.2px}
.tip-desig{font-size:10px;color:var(--text2);line-height:1.4}
.tip-close{margin-left:auto;width:22px;height:22px;border-radius:50%;border:1px solid var(--border);background:transparent;font-size:14px;color:var(--text3);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;line-height:1;transition:all .12s}
.tip-close:hover{background:var(--surface2);color:var(--text)}
.tip-body{padding:10px 14px}
.tip-row{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid var(--border);font-size:11px;gap:8px}
.tip-row:last-child{border-bottom:none}
.tip-key{color:var(--text2);flex-shrink:0}
.tip-val{color:var(--text);font-weight:500;text-align:right;font-family:'DM Mono',monospace;font-size:10px}
.tip-val.plain{font-family:'DM Sans',sans-serif;font-size:11px}
/* avatars */
.av-purple{background:var(--purple);color:#ECEAFF}
.av-teal{background:var(--teal);color:#E0F4EE}
.av-amber{background:var(--amber);color:#FEF0DC}
.av-green{background:var(--green);color:#EAF4E2}
.av-gray{background:#5A5652;color:#F0EEE9}
.av-blue{background:var(--blue);color:#E5EFFC}
.av-indigo{background:var(--indigo);color:#EEF2FF}
.dept-foot{border-top:1px solid var(--border);background:var(--surface);padding:10px 13px;position:sticky;bottom:0;z-index:10}
.kra-label{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);margin-bottom:6px;display:flex;align-items:center;justify-content:space-between}
.kra-add-btn{font-size:10px;padding:1px 8px;border-radius:20px;border:1px dashed var(--border2);background:transparent;color:var(--text3);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .14s}
.kra-add-btn:hover{border-color:var(--purple);color:var(--purple);background:var(--purple-l)}
.kra-item{display:flex;align-items:center;gap:6px;padding:4px 7px;border-radius:6px;border:1px solid var(--border);background:var(--surface2);margin-bottom:4px;font-size:11px;color:var(--text2);cursor:pointer;transition:all .14s}
.kra-item:hover{border-color:var(--border2);background:var(--surface)}
.kra-item-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
.kra-empty{font-size:10px;color:var(--text3);text-align:center;padding:8px 4px;border:1px dashed var(--border);border-radius:6px;cursor:pointer;transition:all .14s}
.kra-empty:hover{border-color:var(--purple);color:var(--purple);background:var(--purple-l)}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:10px}
</style>
</head>
