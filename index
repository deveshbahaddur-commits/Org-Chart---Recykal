const byId={};
EMP.forEach(e=>byId[e.id]=e);

function ini(n){return n.split(' ').slice(0,2).map(w=>w[0]||'').join('').toUpperCase();}
function reps(id){return EMP.filter(e=>(MGRID_REMAP[e.mgrid]||e.mgrid)===id&&e.id!==id&&!e.deptHead);}
function tenure(doj){
  if(!doj)return'—';
  const ms=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const p=doj.split('-');
  const yr=parseInt(p[2])<50?2000+parseInt(p[2]):1900+parseInt(p[2]);
  const diff=(new Date(2026,5,6)-new Date(yr,ms.indexOf(p[1]),parseInt(p[0])))/(864e5*365);
  if(diff<1)return'<1yr';
  const y=Math.floor(diff),mo=Math.floor((diff-y)*12);
  return y+'y'+(mo?' '+mo+'m':'');
}
function avCls(id){
  const e=byId[id];if(!e)return'av-gray';
  const d=(e.dept||'').toLowerCase();
  if(d.includes('sales'))return'av-purple';
  if(d.includes('op'))return'av-teal';
  if(d.includes('audit')||d.includes('comp'))return'av-amber';
  if(d.includes('cap'))return'av-green';
  if(d.includes('legal'))return'av-indigo';
  if(d.includes('finance'))return'av-blue';
  return'av-gray';
}

// ── TOOLTIP ──
function showTip(id,el){
  const e=byId[id];if(!e)return;
  const r=reps(id);
  const isExt=e.isVirtual;
  document.getElementById('tip-head').innerHTML=`
    <div class="tip-av ${avCls(id)}" ${isExt?'style="border:2px dashed #C4A97A"':''}>${ini(e.name)}</div>
    <div style="flex:1;min-width:0">
      <div class="tip-name">${e.name}${isExt?' <span style="font-size:9px;color:var(--text3)">(External)</span>':''}</div>
      <div class="tip-desig">${e.desig}</div>
    </div>
    <button class="tip-close" onclick="hideTip()">×</button>`;
  document.getElementById('tip-body').innerHTML=isExt?`
    <div class="tip-row"><span class="tip-key">Type</span><span class="tip-val plain" style="color:#8B7355">External</span></div>
    <div class="tip-row"><span class="tip-key">Direct reports</span><span class="tip-val plain">${r.length}</span></div>`:`
    <div class="tip-row"><span class="tip-key">Emp ID</span><span class="tip-val">${e.id}</span></div>
    <div class="tip-row"><span class="tip-key">Joined</span><span class="tip-val">${e.doj}</span></div>
    <div class="tip-row"><span class="tip-key">Tenure</span><span class="tip-val plain">${tenure(e.doj)}</span></div>
    <div class="tip-row"><span class="tip-key">Reports to</span><span class="tip-val plain">${e.mgr}</span></div>
    <div class="tip-row"><span class="tip-key">Department</span><span class="tip-val plain">${e.dept||'—'}</span></div>
    ${e.sub?`<div class="tip-row"><span class="tip-key">Function</span><span class="tip-val plain">${e.sub}</span></div>`:''}
    <div class="tip-row"><span class="tip-key">Status</span><span class="tip-val plain" style="color:${e.status==='Active'?'var(--teal)':'var(--red)'}">${e.status}</span></div>
    ${e.isConsultant?`<div class="tip-row"><span class="tip-key">Type</span><span class="tip-val plain" style="color:var(--amber)">Consultant / RIC</span></div>`:''}
    <div class="tip-row"><span class="tip-key">Direct reports</span><span class="tip-val plain">${r.length}</span></div>`;
  const tip=document.getElementById('tip');
  tip.style.display='block';
  const rect=el.getBoundingClientRect();
  const tw=260,th=tip.offsetHeight||260;
  let left=rect.right+10,top=rect.top;
  if(left+tw>window.innerWidth-10)left=rect.left-tw-10;
  if(top+th>window.innerHeight-10)top=window.innerHeight-th-10;
  if(top<10)top=10;
  tip.style.left=left+'px';tip.style.top=top+'px';
}
