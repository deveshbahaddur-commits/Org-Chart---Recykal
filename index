        <span style="flex:1">${k.text}</span>
      </div>`).join('')
    : `<div class="kra-empty" onclick="openKRAEdit('${deptKey}')">+ Add KRAs for ${deptKey}</div>`;
  return `<div class="dept-foot">
    <div class="kra-label">
      <span>KRAs</span>
      <button class="kra-add-btn" onclick="openKRAEdit('${deptKey}')">+ Add</button>
    </div>
    ${items}
  </div>`;
}

function openKRAEdit(dept){
  var current = (KRA_DATA[dept]||[]).map(function(k){return k.text;}).join('\n');
  var input = prompt('KRAs for ' + dept + ' (one per line):', current||'');
  if(input === null) return;
  KRA_DATA[dept] = input.split('\n').filter(function(x){return x.trim();}).map(function(t){return {text:t.trim()};});
  render(currentCC);
}

